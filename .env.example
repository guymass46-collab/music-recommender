# ===================================================================
# Environment Variables Template
# ===================================================================
# העתק את הקובץ הזה ל-.env (בלי ה-.example) ומלא את הערכים האמיתיים.
# הקובץ .env לא יעלה ל-Git (מוגן ב-.gitignore).
# ב-Vercel: הוסף את המשתנים האלה ב-Settings → Environment Variables
# ===================================================================

# Last.fm API Key - השג ב: https://www.last.fm/api/account/create
LASTFM_API_KEY=your_lastfm_api_key_here

# הדומיין שמורשה לקרוא ל-API
# בפיתוח מקומי: http://localhost:3000
# בפרודקשן: https://your-app-name.vercel.app
ALLOWED_ORIGIN=*
